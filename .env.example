# Required — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional — defaults to the public Kapruka MCP server.
# Only change this if Kapruka gives you a different endpoint (e.g. a staging server).
KAPRUKA_MCP_URL=https://mcp.kapruka.com/mcp

# Optional — Claude model used for the concierge.
ANTHROPIC_MODEL=claude-sonnet-4-6
